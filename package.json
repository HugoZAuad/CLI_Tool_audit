{
  "name": "@hugozauad/security-audit-toolkit",
  "version": "0.2.0",
  "description": "Toolkit para auditoria e análise de segurança de projetos Node.js via CLI e como biblioteca.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "security-audit": "./bin/cli.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/cli.js",
    "cli:audit": "tsx src/cli.ts deps-audit",
    "cli:scan": "tsx src/cli.ts code-scan",
    "cli:full": "tsx src/cli.ts full-check"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/HugoZAuad/CLI_Tool_audit"
  },
  "homepage": "https://github.com/HugoZAuad/CLI_Tool_audit/blob/main/README.md",
  "bugs": {
    "url": "https://github.com/HugoZAuad/CLI_Tool_audit/issues"
  },
  "keywords": [
    "security",
    "audit",
    "cli",
    "npm",
    "typescript",
    "security scanner",
    "code analysis",
    "node security",
    "devtools"
  ],
  "author": "Hugo Zeymer Auad <hugozeymer@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^8.0.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^8.57.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "inquirer": "^13.4.1"
  },
  "engines": {
    "node": ">=20"
  }
}